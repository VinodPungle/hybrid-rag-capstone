{
  "dashboard": {
    "id": null,
    "uid": "hybrid-rag-llmops",
    "title": "Hybrid RAG - LLMOps Dashboard",
    "tags": ["llmops", "rag"],
    "timezone": "browser",
    "panels": [
      {
        "id": 1,
        "title": "RAG Requests per Minute",
        "type": "timeseries",
        "gridPos": {"h": 8, "w": 12, "x": 0, "y": 0},
        "targets": [
          {
            "expr": "rate(rag_requests_total[1m])",
            "legendFormat": "{{endpoint}}"
          }
        ]
      },
      {
        "id": 2,
        "title": "Request Latency (p95)",
        "type": "timeseries",
        "gridPos": {"h": 8, "w": 12, "x": 12, "y": 0},
        "targets": [
          {
            "expr": "histogram_quantile(0.95, rate(rag_request_latency_seconds_bucket[5m]))",
            "legendFormat": "{{endpoint}} p95"
          }
        ]
      },
      {
        "id": 3,
        "title": "Total LLM Tokens Consumed",
        "type": "stat",
        "gridPos": {"h": 6, "w": 8, "x": 0, "y": 8},
        "targets": [
          {
            "expr": "sum(llm_tokens_total)",
            "legendFormat": "Total Tokens"
          }
        ]
      },
      {
        "id": 4,
        "title": "LLM Tokens by Type",
        "type": "piechart",
        "gridPos": {"h": 6, "w": 8, "x": 8, "y": 8},
        "targets": [
          {
            "expr": "sum by (token_type) (llm_tokens_total)",
            "legendFormat": "{{token_type}}"
          }
        ]
      },
      {
        "id": 5,
        "title": "Documents Ingested",
        "type": "stat",
        "gridPos": {"h": 6, "w": 8, "x": 16, "y": 8},
        "targets": [
          {
            "expr": "documents_ingested_total",
            "legendFormat": "Documents"
          }
        ]
      },
      {
        "id": 6,
        "title": "LLM Call Latency (p50 / p95 / p99)",
        "type": "timeseries",
        "gridPos": {"h": 8, "w": 12, "x": 0, "y": 14},
        "targets": [
          {
            "expr": "histogram_quantile(0.50, rate(llm_call_latency_seconds_bucket[5m]))",
            "legendFormat": "{{call_type}} p50"
          },
          {
            "expr": "histogram_quantile(0.95, rate(llm_call_latency_seconds_bucket[5m]))",
            "legendFormat": "{{call_type}} p95"
          },
          {
            "expr": "histogram_quantile(0.99, rate(llm_call_latency_seconds_bucket[5m]))",
            "legendFormat": "{{call_type}} p99"
          }
        ]
      },
      {
        "id": 7,
        "title": "Knowledge Graph Size",
        "type": "stat",
        "gridPos": {"h": 8, "w": 12, "x": 12, "y": 14},
        "targets": [
          {
            "expr": "graph_entities_current",
            "legendFormat": "Entities"
          },
          {
            "expr": "graph_relationships_current",
            "legendFormat": "Relationships"
          }
        ]
      }
    ],
    "schemaVersion": 39,
    "version": 1
  }
}
